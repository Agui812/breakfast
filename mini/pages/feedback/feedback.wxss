page {
  background: #FAF7F2;
}

.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  background: #FAF7F2;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D2E1F;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #8B7355;
  margin-top: 8rpx;
  display: block;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 115, 85, 0.06);
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2E1F;
  display: block;
  margin-bottom: 20rpx;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  padding: 16rpx 28rpx;
  background: #F5F0E8;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8B7355;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.type-item:active {
  transform: scale(0.96);
}

.type-item.selected {
  background: linear-gradient(135deg, #FFF5EB, #FFE8D6);
  color: #FF9A56;
  border-color: #FF9A56;
  font-weight: 600;
}

.content-input {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background: #F5F0E8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #3D2E1F;
  box-sizing: border-box;
}

.content-input::placeholder {
  color: #B8A88A;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #B8A88A;
  margin-top: 12rpx;
}

.contact-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F5F0E8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #3D2E1F;
  box-sizing: border-box;
  line-height: 80rpx;
}

.contact-input::placeholder {
  color: #B8A88A;
  font-size: 26rpx;
}

.submit-btn-wrap {
  margin-top: 40rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #FF9A56 0%, #FFB87A 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 86, 0.35);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #E8E0D4;
  color: #B8A88A;
  box-shadow: none;
}

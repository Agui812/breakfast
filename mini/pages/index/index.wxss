page {
  background: #FAF7F2;
}

.container {
  padding-bottom: 160rpx;
  background: #FAF7F2;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  background: linear-gradient(135deg, #FF9A56 0%, #FFB87A 50%, #FFD4A8 100%);
  padding: 50rpx 30rpx 60rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  right: 80rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.92;
  margin-top: 12rpx;
  display: block;
  position: relative;
  z-index: 1;
  letter-spacing: 1rpx;
}

.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.category-list {
  width: 180rpx;
  background: #FAF7F2;
  flex-shrink: 0;
  padding-top: 10rpx;
}

.category-item {
  padding: 32rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8B7355;
  position: relative;
  transition: all 0.2s ease;
}

.category-item.active {
  background: #fff;
  color: #FF9A56;
  font-weight: 600;
  border-radius: 0 16rpx 16rpx 0;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #FF9A56, #FFB87A);
  border-radius: 0 4rpx 4rpx 0;
}

.food-list {
  flex: 1;
  padding: 20rpx;
  background: #FAF7F2;
}

.food-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(139, 115, 85, 0.05);
  position: relative;
  z-index: 1;
}

.food-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 14rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #FFF5EB, #FFE8D6);
  flex-shrink: 0;
}

.food-content {
  flex: 1;
  min-width: 0;
}

.food-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2E1F;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  flex: 1;
  margin-right: 12rpx;
}

.food-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.food-stock {
  font-size: 20rpx;
  color: #B8A88A;
  background: #F5F0E8;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  white-space: nowrap;
  line-height: 1;
}

.soldout-text {
  color: #E85D4A;
  background: #FFF0ED;
}

.food-price {
  font-size: 30rpx;
  color: #FF9A56;
  font-weight: 700;
  flex-shrink: 0;
}

.food-price::before {
  content: '¥';
  font-size: 22rpx;
  font-weight: 500;
}

.food-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  z-index: 10;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
}

.btn-minus,
.btn-plus {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  position: relative;
  z-index: 10;
}

.btn-minus {
  background: #F5F0E8;
  color: #B8A88A;
}

.btn-minus:active {
  background: #EDE6D8;
}

.btn-minus.disabled {
  opacity: 0.35;
}

.btn-plus {
  background: linear-gradient(135deg, #FF9A56, #FFB87A);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 86, 0.3);
}

.btn-plus:active {
  transform: scale(0.92);
}

.quantity {
  font-size: 30rpx;
  min-width: 48rpx;
  text-align: center;
  font-weight: 600;
  color: #3D2E1F;
  position: relative;
  z-index: 10;
}

.soldout-badge {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FFF5EB, #FFE8D6);
  color: #FF9A56;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -8rpx 32rpx rgba(61, 46, 31, 0.08);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 100;
}

.cart-bar.show {
  transform: translateY(0);
}

.cart-bar.expanded {
  border-radius: 0;
}

.cart-info {
  display: flex;
  flex-direction: column;
}

.cart-count {
  font-size: 26rpx;
  color: #8B7355;
}

.cart-total {
  font-size: 40rpx;
  color: #FF9A56;
  font-weight: 700;
  margin-top: 4rpx;
}

.cart-total::before {
  content: '¥';
  font-size: 26rpx;
  font-weight: 500;
}

.checkout-btn {
  background: linear-gradient(135deg, #FF9A56 0%, #FFB87A 100%);
  color: #fff;
  padding: 24rpx 56rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 86, 0.35);
  letter-spacing: 1rpx;
}

.checkout-btn:active {
  transform: scale(0.96);
}

.cart-detail {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(61, 46, 31, 0.12);
  z-index: 99;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  max-height: calc(100vh - 180rpx);
  display: flex;
  flex-direction: column;
}

.cart-detail.show {
  transform: translateY(0);
}

.cart-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F0E8;
  flex-shrink: 0;
}

.cart-detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2E1F;
}

.cart-clear {
  font-size: 24rpx;
  color: #B8A88A;
  padding: 8rpx 16rpx;
}

.cart-detail-list {
  flex: 1;
  padding: 16rpx 30rpx;
  padding-bottom: 220rpx;
  overflow-y: auto;
  max-height: 200rpx;
}

.cart-detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F0E8;
}

.cart-detail-item:last-child {
  border-bottom: none;
}

.cart-detail-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  flex: 1;
  margin-right: 24rpx;
}

.cart-detail-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2E1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-detail-price {
  font-size: 24rpx;
  color: #FF9A56;
  font-weight: 600;
}

.cart-detail-price::before {
  content: '¥';
  font-size: 20rpx;
}

.cart-detail-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

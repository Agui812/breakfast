page {
  background: #FAF7F2;
}

.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  background: #FAF7F2;
  min-height: 100vh;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 115, 85, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D2E1F;
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F0E8;
}

.cart-item:last-child {
  border-bottom: none;
}

.item-name {
  font-size: 30rpx;
  color: #3D2E1F;
  font-weight: 500;
}

.item-detail {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-price {
  font-size: 30rpx;
  color: #FF9A56;
  font-weight: 700;
}

.item-quantity {
  font-size: 28rpx;
  color: #B8A88A;
}

.time-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-slot {
  padding: 20rpx 28rpx;
  background: #F5F0E8;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8B7355;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.time-slot:active {
  transform: scale(0.96);
}

.time-slot.selected {
  background: linear-gradient(135deg, #FFF5EB, #FFE8D6);
  color: #FF9A56;
  border-color: #FF9A56;
  font-weight: 600;
}

.dine-type {
  display: flex;
  gap: 24rpx;
}

.dine-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  background: #F5F0E8;
  border-radius: 24rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.dine-option:active {
  transform: scale(0.96);
}

.dine-option.selected {
  background: linear-gradient(135deg, #FFF5EB, #FFE8D6);
  border-color: #FF9A56;
}

.dine-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.dine-text {
  font-size: 28rpx;
  color: #8B7355;
  font-weight: 500;
}

.dine-option.selected .dine-text {
  color: #FF9A56;
  font-weight: 600;
}

.seat-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #F5F0E8;
  border-radius: 16rpx;
}

.seat-label {
  font-size: 28rpx;
  color: #8B7355;
}

.seat-value {
  font-size: 30rpx;
  color: #FF9A56;
  font-weight: 600;
}

.phone-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F5F0E8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #3D2E1F;
  box-sizing: border-box;
  line-height: 80rpx;
}

.phone-input::placeholder {
  color: #B8A88A;
  font-size: 26rpx;
}

.summary {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 115, 85, 0.06);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #8B7355;
  padding: 8rpx 0;
}

.total-price {
  font-size: 44rpx;
  color: #FF9A56;
  font-weight: 700;
}

.total-price::before {
  content: '¥';
  font-size: 28rpx;
  font-weight: 500;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 32rpx rgba(61, 46, 31, 0.08);
  border-radius: 32rpx 32rpx 0 0;
}

.submit-btn {
  background: linear-gradient(135deg, #FF9A56 0%, #FFB87A 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 86, 0.35);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #E8E0D4;
  color: #B8A88A;
  box-shadow: none;
}

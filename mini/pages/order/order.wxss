page {
  background: #FAF7F2;
}

.container {
  padding: 20rpx;
  background: #FAF7F2;
  min-height: 100vh;
}

.order-list {
  padding-bottom: 20rpx;
}

.order-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(139, 115, 85, 0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #FFF5EB, #FFE8D6);
  border-bottom: 1rpx solid #F5F0E8;
}

.order-no {
  font-size: 24rpx;
  color: #8B7355;
}

.order-status {
  font-size: 26rpx;
  color: #FF9A56;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-completed {
  color: #4CAF50;
}

.status-picked {
  color: #B8A88A;
}

.order-body {
  padding: 30rpx;
}

.order-items {
  margin-bottom: 20rpx;
}

.item-text {
  display: block;
  font-size: 30rpx;
  color: #3D2E1F;
  line-height: 1.6;
}

.order-info {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx dashed #F5F0E8;
}

.pickup-code {
  font-size: 34rpx;
  color: #FF9A56;
  font-weight: 700;
}

.pickup-time {
  font-size: 26rpx;
  color: #8B7355;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #FAF7F2;
  border-top: 1rpx solid #F5F0E8;
}

.order-total {
  font-size: 38rpx;
  color: #FF9A56;
  font-weight: 700;
}

.order-total::before {
  content: '¥';
  font-size: 26rpx;
  font-weight: 500;
}

.order-time {
  font-size: 22rpx;
  color: #B8A88A;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #8B7355;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #B8A88A;
}
